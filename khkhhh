<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام حسابات منجم الذهب</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Tajawal', sans-serif;
            background-color: #f3f4f6;
        }
        .card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .gold-border {
            border-top: 4px solid #d4af37;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-6xl mx-auto">
        <!-- Header & Download -->
        <header class="mb-8 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-right">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">نظام إدارة إنتاج وحسابات المنجم</h1>
                <p class="text-gray-600 mt-2">توزيع حصص العمال والمنجم وحساب المصروفات والقيم النقدية</p>
            </div>
            <!-- زر التحميل المباشر -->
            <button onclick="downloadSelf()" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-full font-bold shadow-lg flex items-center gap-2 transition transform hover:scale-105">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                تنزيل الملف (للعمل أوفلاين)
            </button>
        </header>

        <!-- Global Settings (Price per Gram) -->
        <div class="card p-4 mb-8 bg-yellow-50 border-r-4 border-yellow-500 flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-yellow-500 p-2 rounded-full text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-gray-800">سعر الجرام الحالي</h3>
                    <p class="text-xs text-gray-500">تغيير هذا السعر سيحدث كافة المبالغ النقدية فوراً</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <input type="number" id="gramPrice" oninput="updateUI()" onkeyup="updateUI()" value="1" step="0.01" class="text-xl font-bold p-2 w-32 border border-yellow-400 rounded-md text-center focus:ring-yellow-500 focus:border-yellow-500 bg-white shadow-sm">
                <span class="font-bold text-gray-700">عملة / جرام</span>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Left Column: Inputs -->
            <div class="lg:col-span-1 space-y-6">
                <div class="card p-6 gold-border">
                    <h2 class="text-xl font-bold mb-4 border-b pb-2 text-yellow-600">إدخال إنتاج جديد</h2>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">وزن الذهب الكلي (جرام)</label>
                            <input type="number" id="goldInput" placeholder="0.00" class="mt-1 block w-full p-3 border border-gray-300 rounded-md focus:ring-yellow-500 focus:border-yellow-500">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700">رسوم الطحن (جرام)</label>
                            <input type="number" id="millingInput" placeholder="0.00" class="mt-1 block w-full p-3 border border-gray-300 rounded-md focus:ring-yellow-500 focus:border-yellow-500">
                        </div>

                        <button onclick="addProduction()" class="w-full bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-3 rounded-md transition duration-200">
                            إضافة للإنتاج
                        </button>
                    </div>
                </div>

                <div class="card p-6 border-t-4 border-red-500">
                    <h2 class="text-xl font-bold mb-4 border-b pb-2 text-red-600">المصروفات العامة</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 text-red-700 font-bold">المبلغ المطلوب خصمه</label>
                            <div class="flex gap-2">
                                <input type="number" id="expenseAmount" placeholder="0.00" class="flex-1 p-3 border border-gray-300 rounded-md">
                                <select id="expenseUnit" class="p-3 border border-gray-300 rounded-md bg-gray-50 font-bold">
                                    <option value="gram">جرام</option>
                                    <option value="cash">نقداً</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700">البيان</label>
                            <input type="text" id="expenseNote" placeholder="مثلاً: ديزل، صيانة..." class="mt-1 block w-full p-3 border border-gray-300 rounded-md">
                        </div>
                        <button onclick="addExpense()" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-md transition duration-200">
                            إضافة مصروف
                        </button>
                    </div>
                </div>

                <button onclick="clearAllData()" class="w-full text-gray-400 hover:text-red-500 text-sm py-2 border border-dashed border-gray-300 rounded mt-4">مسح كافة البيانات وإعادة الضبط</button>
            </div>

            <!-- Right Column: Results & Tables -->
            <div class="lg:col-span-2 space-y-6">
                
                <!-- Summary Dashboard -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="card p-4 bg-blue-50 border-r-4 border-blue-500">
                        <p class="text-sm text-blue-600 font-bold">إجمالي إنتاج المنجم (60%)</p>
                        <h3 id="totalMineShareDisplay" class="text-2xl font-bold text-gray-800">0.00 <span class="text-sm">جرام</span></h3>
                        <p id="totalMineCashDisplay" class="text-blue-800 font-bold text-lg mt-1">0.00 عملة</p>
                    </div>
                    <div class="card p-4 bg-green-50 border-r-4 border-green-500">
                        <p class="text-sm text-green-600 font-bold">صافي الربح المتبقي (بعد المصروفات)</p>
                        <h3 id="netProfitDisplay" class="text-2xl font-bold text-gray-800">0.00 <span class="text-sm">جرام</span></h3>
                        <p id="netProfitCashDisplay" class="text-green-800 font-bold text-lg mt-1">0.00 عملة</p>
                    </div>
                </div>

                <!-- Production Table -->
                <div class="card overflow-hidden text-right">
                    <div class="bg-gray-100 p-4 font-bold border-b flex justify-between items-center text-sm md:text-base">
                        <span>سجل الإنتاج</span>
                        <span class="text-xs bg-yellow-200 text-yellow-800 px-2 py-1 rounded">الحصص بعد خصم الطحن</span>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 text-xs md:text-sm">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-3 py-3 text-right font-medium text-gray-500">الوزن</th>
                                    <th class="px-3 py-3 text-right font-medium text-red-500">طحن</th>
                                    <th class="px-3 py-3 text-right font-medium text-blue-600">المنجم</th>
                                    <th class="px-3 py-3 text-right font-medium text-blue-800 font-bold">القيمة</th>
                                    <th class="px-3 py-3 text-right font-medium text-green-600">العامل</th>
                                    <th class="px-3 py-3"></th>
                                </tr>
                            </thead>
                            <tbody id="productionTableBody" class="bg-white divide-y divide-gray-200">
                                <!-- Data -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Expenses Table -->
                <div class="card overflow-hidden text-right">
                    <div class="bg-gray-100 p-4 font-bold border-b text-red-700">سجل مصروفات المنجم</div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 text-xs md:text-sm">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-right font-medium text-gray-500">البيان</th>
                                    <th class="px-4 py-3 text-right font-medium text-gray-500">جرام</th>
                                    <th class="px-4 py-3 text-right font-medium text-gray-500">نقدي</th>
                                    <th class="px-4 py-3"></th>
                                </tr>
                            </thead>
                            <tbody id="expensesTableBody" class="bg-white divide-y divide-gray-200">
                                <!-- Data -->
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div id="msgBox" class="fixed bottom-4 left-4 transform transition-all duration-300 translate-y-20 opacity-0 z-50">
        <div class="bg-gray-800 text-white px-6 py-3 rounded-lg shadow-xl" id="msgContent"></div>
    </div>

    <script>
        // Load data from localStorage if exists
        let productions = JSON.parse(localStorage.getItem('mine_productions')) || [];
        let expenses = JSON.parse(localStorage.getItem('mine_expenses')) || [];

        function showMsg(text) {
            const box = document.getElementById('msgBox');
            document.getElementById('msgContent').innerText = text;
            box.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(() => {
                box.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        function getGramPrice() {
            let price = parseFloat(document.getElementById('gramPrice').value);
            return (isNaN(price) || price <= 0) ? 1 : price;
        }

        function saveData() {
            localStorage.setItem('mine_productions', JSON.stringify(productions));
            localStorage.setItem('mine_expenses', JSON.stringify(expenses));
        }

        function addProduction() {
            const total = parseFloat(document.getElementById('goldInput').value);
            const milling = parseFloat(document.getElementById('millingInput').value) || 0;

            if (!total || total <= 0) {
                showMsg("يرجى إدخال وزن الذهب بشكل صحيح");
                return;
            }
            if (milling >= total) {
                showMsg("رسوم الطحن لا يمكن أن تكون أكبر من الإنتاج الكلي");
                return;
            }

            const afterMilling = total - milling;
            const mineShare = afterMilling * 0.60;
            const workerShare = afterMilling * 0.40;

            productions.push({
                id: Date.now(),
                total,
                milling,
                afterMilling,
                mineShare,
                workerShare
            });
            
            saveData();
            updateUI();
            document.getElementById('goldInput').value = '';
            document.getElementById('millingInput').value = '';
        }

        function addExpense() {
            const amount = parseFloat(document.getElementById('expenseAmount').value);
            const note = document.getElementById('expenseNote').value;
            const unit = document.getElementById('expenseUnit').value;

            if (!amount || amount <= 0) {
                showMsg("يرجى إدخال قيمة المصروف");
                return;
            }

            expenses.push({ 
                id: Date.now(), 
                value: amount, 
                unit: unit,    
                note: note || "بدون بيان"
            });
            
            saveData();
            updateUI();
            document.getElementById('expenseAmount').value = '';
            document.getElementById('expenseNote').value = '';
        }

        function deleteProduction(id) {
            productions = productions.filter(p => p.id !== id);
            saveData();
            updateUI();
        }

        function deleteExpense(id) {
            expenses = expenses.filter(e => e.id !== id);
            saveData();
            updateUI();
        }

        function clearAllData() {
            if(confirm("هل أنت متأكد من مسح كافة البيانات؟ لا يمكن التراجع عن هذه الخطوة.")) {
                productions = [];
                expenses = [];
                localStorage.removeItem('mine_productions');
                localStorage.removeItem('mine_expenses');
                updateUI();
                showMsg("تم مسح كافة البيانات بنجاح");
            }
        }

        function updateUI() {
            const currentPrice = getGramPrice();
            
            const pTable = document.getElementById('productionTableBody');
            pTable.innerHTML = '';
            let totalMineGrams = 0;

            productions.forEach(p => {
                totalMineGrams += p.mineShare;
                const mineCash = p.mineShare * currentPrice;
                pTable.innerHTML += `
                    <tr class="hover:bg-gray-50 border-b">
                        <td class="px-3 py-3 font-medium text-gray-700">${p.total.toFixed(2)}</td>
                        <td class="px-3 py-3 text-red-500">${p.milling.toFixed(2)}</td>
                        <td class="px-3 py-3 text-blue-600 font-bold">${p.mineShare.toFixed(2)}</td>
                        <td class="px-3 py-3 text-blue-800 font-bold bg-blue-50">${mineCash.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                        <td class="px-3 py-3 text-green-600 font-bold">${p.workerShare.toFixed(2)}</td>
                        <td class="px-3 py-3 text-left">
                            <button onclick="deleteProduction(${p.id})" class="text-red-400 hover:text-red-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </td>
                    </tr>
                `;
            });

            const eTable = document.getElementById('expensesTableBody');
            eTable.innerHTML = '';
            let totalExpensesGrams = 0;

            expenses.forEach(e => {
                let gVal, cVal;
                if (e.unit === 'gram') {
                    gVal = e.value;
                    cVal = e.value * currentPrice;
                } else {
                    cVal = e.value;
                    gVal = e.value / currentPrice;
                }
                
                totalExpensesGrams += gVal;
                
                eTable.innerHTML += `
                    <tr class="hover:bg-gray-50 border-b">
                        <td class="px-4 py-3">${e.note}</td>
                        <td class="px-4 py-3 text-red-500 font-medium">${gVal.toFixed(3)}</td>
                        <td class="px-4 py-3 text-red-700 font-bold bg-red-50">${cVal.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                        <td class="px-4 py-3 text-left">
                            <button onclick="deleteExpense(${e.id})" class="text-red-400 hover:text-red-600">حذف</button>
                        </td>
                    </tr>
                `;
            });

            const totalMineCash = totalMineGrams * currentPrice;
            const netProfitGrams = totalMineGrams - totalExpensesGrams;
            const netProfitCash = netProfitGrams * currentPrice;
            
            document.getElementById('totalMineShareDisplay').innerHTML = `${totalMineGrams.toFixed(2)} <span class="text-sm font-normal">جرام</span>`;
            document.getElementById('totalMineCashDisplay').innerText = `${totalMineCash.toLocaleString(undefined, {minimumFractionDigits: 2})} عملة`;
            
            document.getElementById('netProfitDisplay').innerHTML = `${netProfitGrams.toFixed(2)} <span class="text-sm font-normal">جرام</span>`;
            document.getElementById('netProfitCashDisplay').innerText = `${netProfitCash.toLocaleString(undefined, {minimumFractionDigits: 2})} عملة`;
            
            const netPriceColor = netProfitGrams < 0 ? 'text-red-600' : 'text-green-700';
            document.getElementById('netProfitCashDisplay').className = `${netPriceColor} font-bold text-lg mt-1`;
        }

        // وظيفة تحميل الكود كملف HTML منفصل
        function downloadSelf() {
            // نقوم بنسخ كود الصفحة بالكامل
            const htmlContent = `<!DOCTYPE html>
<html lang="ar" dir="rtl">
${document.documentElement.innerHTML}
</html>`;
            const blob = new Blob([htmlContent], { type: 'text/html' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            const date = new Date().toLocaleDateString('ar-EG').replace(/\//g, '-');
            a.href = url;
            a.download = `حسابات_المنجم_${date}.html`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
            showMsg("بدأ تحميل الملف...");
        }

        window.onload = updateUI;
    </script>
</body>
</html>
